# ---------------------------------------------------------------------------
# TradingAgents API - low-cost starter config (Bayside / Anthropic standard)
# Copy to ".env" in your repo root and fill in your real key.
# These TRADINGAGENTS_* vars are read automatically by default_config.py.
# ---------------------------------------------------------------------------

# --- Anthropic (Claude) - matches the Bayside ecosystem standard ---
# IMPORTANT: generate this key INSIDE the "Bayside n8n" Anthropic workspace so
# the US$30 workspace spend cap governs it (same rule as the n8n key).
ANTHROPIC_API_KEY=sk-ant-replace-me
TRADINGAGENTS_LLM_PROVIDER=anthropic

# Cheap-but-capable model split. Haiku for both to start (cheapest). Bump the
# deep-think model to claude-sonnet-4-6 later if you want stronger analysis.
TRADINGAGENTS_DEEP_THINK_LLM=claude-haiku-4-5
TRADINGAGENTS_QUICK_THINK_LLM=claude-haiku-4-5

# Keep Anthropic effort modest to control cost (low | medium | high)
# (leave unset to use the provider default)
# TRADINGAGENTS_ANTHROPIC_EFFORT=low

# --- Cost controls (fewer rounds + fewer articles = fewer tokens) ---
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1

# Which analyst agents to run. Fewer = cheaper. Full set is:
# market,social,news,fundamentals
# For the cheapest useful run, try: market,news
TA_SELECTED_ANALYSTS=market,social,news,fund