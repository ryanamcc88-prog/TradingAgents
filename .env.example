# ---------------------------------------------------------------------------
# TradingAgents API - low-cost starter config
# Copy to ".env" in your repo root and fill in your real key.
# These TRADINGAGENTS_* vars are read automatically by default_config.py.
# ---------------------------------------------------------------------------

# --- LLM provider + your key (pick ONE provider) ---
OPENAI_API_KEY=sk-replace-me
TRADINGAGENTS_LLM_PROVIDER=openai

# Cheap-but-capable model split. The "deep think" model does the heavy
# reasoning, "quick think" does the lighter steps. Keeping both on a small
# model is the single biggest cost lever. Swap up later if you want.
TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4-mini
TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini

# --- Cost controls (fewer rounds + fewer articles = fewer tokens) ---
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1

# Which analyst agents to run. Fewer = cheaper. Full set is:
# market,social,news,fundamentals
# For the cheapest useful run, try: market,news
TA_SELECTED_ANALYSTS=market,social,news,fundamentals

# --- API server ---
TA_API_HOST=0.0.0.0
TA_API_PORT=8000

# --- Optional: persist the decision log somewhere stable ---
# TRADINGAGENTS_MEMORY_LOG_PATH=/data/trading_memory.md

# --- Optional extra data keys (improve coverage; not required to start) ---
# ALPHA_VANTAGE_API_KEY=
# FRED_API_KEY=
